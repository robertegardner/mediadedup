# A single parent directory on the host that contains every share you want
# to scan. Bound into containers as /media. Sources are configured at runtime
# via the web UI; each one is a subdirectory of /media.
#
# Example: if you have host mounts at /mnt/whisparr, /mnt/music, /mnt/archive,
# set MEDIA_PATH=/mnt and configure sources with paths
# /media/whisparr, /media/music, /media/archive in the web UI.
MEDIA_PATH=/mnt

# Legacy bootstrap (optional). On a fresh install with no sources configured,
# these create default 'video' and 'music' sources pointing at the given
# in-container paths. Once you've added your real sources via the web UI,
# you can ignore these.
VIDEO_ROOT=/media/video
MUSIC_ROOT=/media/music

# Web UI
WEB_PORT=8088

# Database
DB_NAME=mediadedup
DB_USER=mediadedup
DB_PASS=changeme-please

# Workers
WORKER_REPLICAS=2

# Video perceptual-hash settings
VIDEO_PHASH_FRAMES=16          # frames sampled per video for fingerprinting
VIDEO_PHASH_THRESHOLD=12       # max avg Hamming distance (0-64) to call a match.
                               # 12 is friendly to cross-resolution dupes (1080p
                               # vs 720p of the same source). Lower for stricter
                               # matching, raise (16-20) if you're missing dupes.
VIDEO_DURATION_TOLERANCE=3     # ±N seconds when bucketing candidates. Raise to
                               # 5+ if your dupes have slightly different runtimes
                               # (cropped intros/outros, different cuts).
VIDEO_USE_GPU=1                # 1 = use NVDEC, 0 = CPU decode

# Audio Chromaprint match threshold (0..1). Higher = stricter.
CHROMAPRINT_THRESHOLD=0.85

# Resilience: per-call timeouts inside the worker
SHA_TIMEOUT_SECS=600           # max time for SHA-256 of one file (10 min default)
STAT_TIMEOUT_SECS=30           # max time for a single stat() call

# Resilience: stuck-row reaper running inside the web container
REAPER_STUCK_THRESHOLD_SECS=1800   # rows in 'processing' longer than this get
                                   # bumped back to pending and re-enqueued (30 min)
REAPER_INTERVAL_SECS=120           # how often the reaper checks (2 min)

# Periodic scanner + matcher schedule (runs in the web container)
# Five-field cron expression, UTC. Set to empty string to disable.
# Examples:
#   "0 4 * * *"      - daily at 04:00 UTC
#   "0 */6 * * *"    - every 6 hours
#   "0 4 * * 0"      - weekly, Sundays at 04:00 UTC
DEDUP_SCHEDULE_CRON=0 4 * * *

# After each scheduled run completes, optionally auto-delete duplicates.
# Same logic as the dashboard buttons, so files MOVE to .mediadedup-trash/.
DEDUP_AUTO_DELETE_EXACT=0          # set to 1 to auto-delete exact (sha256) dupes
DEDUP_AUTO_DELETE_SIM_THRESHOLD=   # set to e.g. 0.98 to also auto-delete
                                   # similarity matches at/above that score.
                                   # Leave empty to disable.
